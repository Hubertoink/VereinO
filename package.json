{
  "name": "verein-budget-planner",
  "version": "2.8.1",
  "private": true,
  "description": "Offline-first Electron app for non-profit finance planning (Windows/macOS/Linux)",
  "main": "dist-electron/main/index.cjs",
  "author": "Nikolas Häfner",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "predev": "node scripts/ensure-electron-arch.cjs",
    "dev": "electron-vite dev",
    "prebuild": "node scripts/ensure-electron-arch.cjs",
    "build": "electron-vite build",
    "prepackage": "npm run build",
    "release:artifacts": "npm run package",
    "release:publish": "node scripts/publish-release.cjs",
    "prepreview": "node scripts/ensure-electron-arch.cjs",
    "preview": "electron-vite preview",
    "lint": "eslint .",
    "typecheck": "node node_modules/typescript/bin/tsc -b --pretty false",
    "typecheck:ts7": "node node_modules/typescript-7/bin/tsc -b --pretty false",
    "verify": "npm run lint && npm run typecheck && npm run typecheck:ts7 && npm test -- --runInBand",
    "format": "prettier --write .",
    "test": "jest",
    "pretest:e2e": "npm run rebuild:native",
    "test:e2e": "playwright test",
    "rebuild:native": "node scripts/ensure-electron-arch.cjs && node scripts/rebuild-native.cjs",
    "postinstall": "playwright install",
    "package": "electron-builder -c electron-builder.yml",
    "start": "npm run dev"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.6.2",
    "electron-updater": "^6.3.9",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.2.5",
    "openai": "^6.45.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.530",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@types/react": "^18.2.74",
    "@types/react-dom": "^18.2.24",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "@vitejs/plugin-react": "^5.2.0",
    "baseline-browser-mapping": "^2.9.2",
    "electron": "^39.8.10",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.7",
    "jest": "^29.7.0",
    "jest-junit": "^17.0.0",
    "node-gyp": "^12.4.0",
    "playwright": "^1.47.2",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "typescript-7": "npm:typescript@^7.0.2",
    "vite": "^7.3.6"
  },
  "overrides": {
    "exceljs": {
      "uuid": "^11.1.1"
    }
  }
}
